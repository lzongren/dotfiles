#!/bin/bash
# devbox — connect to a remote dev host over mosh, auto-attaching a persistent
# tmux session. Your work runs THERE; local files are bridged via Mutagen
# (see remote-dev/README.md). Host comes from ~/.config/devbox/config (copy
# remote-dev/config.example); nothing host-specific lives in this repo.
#
# Pairs with `dev` (local workspace launcher): use `devbox` to reach the
# remote, then `dev <project>` on the remote for the claude/yazi/lazygit layout.
#
# Usage: devbox [session-name]     (default session: main)
#        devbox list              (show running sessions, don't connect)
#        devbox status            (session table: state, idle, cmd, path)
#        devbox doctor            (health-check every layer)
#        devbox sync [ls|add|rm]  (manage synced folders)
#        devbox --raw             (plain mosh, no tmux)

# Load host config (gitignored, lives outside the repo). Only DEVBOX_HOST is
# needed here; mosh-server and tmux resolve on the remote PATH (~/.local/bin
# via .zshenv), so no host-specific paths are required.
DEVBOX_CONFIG="${DEVBOX_CONFIG:-$HOME/.config/devbox/config}"
# shellcheck source=/dev/null
[ -f "$DEVBOX_CONFIG" ] && . "$DEVBOX_CONFIG"
DEVBOX_HOST="${DEVBOX_HOST:-dev}"

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
  echo "  host: $DEVBOX_HOST  (config: $DEVBOX_CONFIG)"
  if [[ -n "${DEVBOX_SYNCS:-}" ]]; then
    echo "  synced folders (Mutagen):"
    while IFS='|' read -r name local remote; do
      [[ -n "$name" ]] && printf '    %-10s %s  ⇄  %s\n' "$name" "$local" "$remote"
    done <<<"$DEVBOX_SYNCS"
  fi
  exit 0
fi

if [[ "$1" == "doctor" || "$1" == "check" ]]; then
  # Health-check every layer between laptop and remote. Prints one line per
  # check; exits non-zero if any hard check FAILs (warnings don't fail).
  # shellcheck disable=SC2015  # `check && pass || fail` is deliberate: pass/fail are printf, never fail
  g=$'\033[32m'
  y=$'\033[33m'
  r=$'\033[31m'
  d=$'\033[2m'
  z=$'\033[0m'
  fails=0
  pass() { printf '  %s✓%s %s\n' "$g" "$z" "$1"; }
  warn() { printf '  %s!%s %s %s%s%s\n' "$y" "$z" "$1" "$d" "${2:-}" "$z"; }
  fail() {
    printf '  %s✗%s %s %s%s%s\n' "$r" "$z" "$1" "$d" "${2:-}" "$z"
    fails=$((fails + 1))
  }

  echo "devbox doctor — host: $DEVBOX_HOST"

  # --- local tools ---
  command -v mosh >/dev/null && pass "mosh installed (laptop)" || fail "mosh missing (laptop)" "brew install mosh"
  MUTAGEN="$(command -v mutagen || echo "$HOME/bin/mutagen")"
  [ -x "$MUTAGEN" ] && pass "mutagen installed (laptop)" || fail "mutagen missing (laptop)" "run remote-dev/setup-sync.sh"

  # --- remote reachability (single ssh, gather everything at once) ---
  # Fields are newline-separated key=value; values may contain spaces, so parse
  # line-by-line instead of eval (which would split "up 2 days" into commands).
  # shellcheck disable=SC2016  # the $(...) below intentionally run on the remote
  probe="$(timeout 20 ssh -o ConnectTimeout=10 "$DEVBOX_HOST" '
    echo "UP=$(uptime | grep -oE "up [^,]*" | head -1)"
    echo "TMUX=$(command -v tmux || echo MISSING)"
    echo "MOSH=$(command -v mosh-server || echo MISSING)"
    echo "DISK=$(df --output=pcent "$HOME" 2>/dev/null | tail -1 | tr -dc 0-9)"
    echo "SESSIONS=$(tmux ls 2>/dev/null | wc -l | tr -d " ")"
    echo "ORPHANS=$(pgrep -c mosh-server 2>/dev/null || echo 0)"
  ' 2>/dev/null)"
  if [ -z "$probe" ]; then
    fail "remote unreachable ($DEVBOX_HOST)" "rebooting? check VPN / ssh $DEVBOX_HOST"
  else
    UP=""
    TMUX=""
    MOSH=""
    DISK=""
    SESSIONS=0
    ORPHANS=0
    while IFS='=' read -r k v; do
      case "$k" in
        UP) UP="$v" ;; TMUX) TMUX="$v" ;; MOSH) MOSH="$v" ;;
        DISK) DISK="$v" ;; SESSIONS) SESSIONS="$v" ;; ORPHANS) ORPHANS="$v" ;;
      esac
    done <<<"$probe"
    pass "remote reachable (${UP:-up})"
    [ "$TMUX" != MISSING ] && pass "tmux on remote PATH" || fail "tmux not on remote PATH" "run setup-remote.sh; check ~/.zshenv"
    [ "$MOSH" != MISSING ] && pass "mosh-server on remote PATH" || fail "mosh-server not on remote PATH" "run setup-remote.sh"
    if [ -n "${DISK:-}" ]; then
      if [ "$DISK" -ge 95 ]; then
        fail "remote disk ${DISK}% full" "frees nothing until cleaned — tmux/mosh/sync will break"
      elif [ "$DISK" -ge 85 ]; then
        warn "remote disk ${DISK}% full" "getting tight"
      else pass "remote disk ${DISK}% used"; fi
    fi
    if [ "${SESSIONS:-0}" -gt 0 ]; then pass "$SESSIONS tmux session(s) alive"; else warn "no tmux sessions" "devbox <name> starts one"; fi
    [ "${ORPHANS:-0}" -gt 5 ] && warn "$ORPHANS mosh-servers running" "orphans piling up; kill stale ones"
  fi

  # --- mutagen daemon + per-session connection ---
  if [ -x "$MUTAGEN" ]; then
    if "$MUTAGEN" daemon status >/dev/null 2>&1 || "$MUTAGEN" sync list >/dev/null 2>&1; then
      pass "mutagen daemon running"
      list="$("$MUTAGEN" sync list 2>/dev/null)"
      names="$(printf '%s\n' "$list" | grep -oE 'Name: [a-zA-Z0-9_-]+' | awk '{print $2}')"
      if [ -z "$names" ]; then
        warn "no sync sessions" "run remote-dev/setup-sync.sh"
      else
        # A healthy session shows two "Connected: Yes"; a stalled one shows No/Halted.
        while read -r n; do
          [ -n "$n" ] || continue
          block="$("$MUTAGEN" sync list "$n" 2>/dev/null)"
          conn="$(printf '%s\n' "$block" | grep -c 'Connected: Yes')"
          status="$(printf '%s\n' "$block" | grep -m1 'Status:' | sed 's/.*Status: *//')"
          if [ "$conn" -ge 2 ]; then
            pass "sync '$n' connected ${d}($status)${z}"
          else fail "sync '$n' not connected" "status: ${status:-unknown}; mutagen sync reset $n"; fi
        done <<<"$names"
      fi
    else
      fail "mutagen daemon not running" "mutagen daemon start"
    fi
  fi

  echo
  if [ "$fails" -eq 0 ]; then
    printf '%sAll checks passed.%s\n' "$g" "$z"
    exit 0
  else
    printf '%s%d check(s) failed.%s\n' "$r" "$fails" "$z"
    exit 1
  fi
fi

if [[ "$1" == "sync" ]]; then
  # Manage synced folders. Config mutation lives in lib.sh (devbox_config_*),
  # which is what the bats tests exercise; this wrapper adds arg parsing, ~
  # expansion, and applying/terminating the live Mutagen session.
  _lib="$(cd "$(dirname "$0")/../remote-dev" 2>/dev/null && pwd)/lib.sh"
  if [ ! -f "$_lib" ]; then
    echo "devbox: cannot find remote-dev/lib.sh" >&2
    exit 1
  fi
  # shellcheck source=/dev/null
  . "$_lib"
  MUT="$(devbox_mutagen)"

  case "${2:-ls}" in
    ls | list | "")
      if ! devbox_syncs_list "$DEVBOX_CONFIG" | grep -q .; then
        echo "No synced folders configured."
        exit 0
      fi
      printf '%-12s %-40s %s\n' NAME LOCAL REMOTE
      devbox_syncs_list "$DEVBOX_CONFIG" | while IFS='|' read -r n l r; do printf '%-12s %-40s %s\n' "$n" "$l" "$r"; done
      ;;

    add)
      name="${3:-}"
      local_path="${4:-}"
      remote="${5:-${3:-}}" # default remote = name
      [ -n "$name" ] && [ -n "$local_path" ] || {
        echo "usage: devbox sync add <name> <local-path> [remote-path]" >&2
        exit 1
      }
      local_path="${local_path/#\~/$HOME}" # expand leading ~
      [ -d "$local_path" ] || {
        echo "devbox: local path not a directory: $local_path" >&2
        exit 1
      }
      devbox_config_add "$DEVBOX_CONFIG" "$name" "$local_path" "$remote" || exit 1
      echo "✓ added '$name' to $DEVBOX_CONFIG"
      if [ -n "$MUT" ]; then
        DEVBOX_SYNCS="" # reload for devbox_sync_create
        # shellcheck source=/dev/null
        . "$DEVBOX_CONFIG"
        devbox_sync_create "$name" "$local_path" "$remote" && echo "✓ sync '$name' created" ||
          echo "devbox: added to config but sync create failed — run remote-dev/setup-sync.sh" >&2
      else
        echo "devbox: mutagen not installed; run remote-dev/setup-sync.sh to apply" >&2
      fi
      ;;

    rm | remove | delete)
      name="${3:-}"
      [ -n "$name" ] || {
        echo "usage: devbox sync rm <name>" >&2
        exit 1
      }
      devbox_config_rm "$DEVBOX_CONFIG" "$name" || exit 1
      echo "✓ removed '$name' from $DEVBOX_CONFIG"
      # Terminate the live session (leaves files in place on both sides).
      [ -n "$MUT" ] && "$MUT" sync terminate "$name" 2>/dev/null && echo "✓ sync '$name' terminated (files kept on both sides)"
      ;;

    *)
      echo "usage: devbox sync [ls|add <name> <local> [remote]|rm <name>]" >&2
      exit 1
      ;;
  esac
  exit 0
fi

if [[ "$1" == "list" || "$1" == "ls" ]]; then
  exec ssh "$DEVBOX_HOST" tmux ls # quick query, no mosh/attach
fi

if [[ "$1" == "status" ]]; then
  # Machine-readable status: one line per session (name|attached|ago|cmd|path).
  # --raw: skip the pretty table, emit raw pipe-delimited lines for scripts.
  _lib="$(cd "$(dirname "$0")/../remote-dev" 2>/dev/null && pwd)/lib.sh"
  # shellcheck source=/dev/null
  [ -f "$_lib" ] && . "$_lib"
  probe="$(timeout 10 ssh -o ConnectTimeout=5 "$DEVBOX_HOST" '
    tmux list-sessions -F "S|#{session_name}|#{session_attached}|#{session_activity}" 2>/dev/null
    tmux list-panes -a -F "P|#{session_name}|#{window_active}|#{pane_active}|#{window_bell_flag}|#{pane_current_command}|#{pane_current_path}" 2>/dev/null
  ' 2>/dev/null)" || {
    echo "devbox: cannot reach $DEVBOX_HOST" >&2
    exit 1
  }
  [ -z "$probe" ] && {
    echo "No sessions."
    exit 0
  }
  merged="$(printf '%s\n' "$probe" | devbox_status_lines)"
  if [[ "${2:-}" == "--raw" ]]; then
    printf '%s\n' "$merged"
  elif [[ "${2:-}" == "--summary" ]]; then
    # Natural language summary via claude (requires claude CLI on PATH).
    now="$(date +%s)"
    table=""
    while IFS='|' read -r name att act bell cmd path; do
      [ -n "$name" ] || continue
      idle="$(devbox_ago "$now" "$act")"
      att_str="attached"
      [ "$att" = 0 ] && att_str="detached"
      bell_str=""
      [ "$bell" = 1 ] && bell_str=" [NEEDS ATTENTION]"
      table+="- ${name}: ${att_str}, idle ${idle}, running ${cmd:-shell} in ${path}${bell_str}"$'\n'
    done <<<"$merged"
    printf '%s\n' "$table" | claude --model haiku -p \
      'Summarize these tmux sessions in 1-2 sentences for a developer checking in after a break. Be specific about what work seems active. Sessions marked NEEDS ATTENTION rang their bell (e.g. a command finished or wants input). No preamble.' 2>/dev/null ||
      printf '%s' "$table"
  else
    now="$(date +%s)"
    printf '%-20s %-6s %-6s %-4s %-10s %s\n' SESSION STATE IDLE BELL CMD PATH
    while IFS='|' read -r name att act bell cmd path; do
      [ -n "$name" ] || continue
      state="●"
      [ "$att" = 0 ] && state="○"
      idle="$(devbox_ago "$now" "$act")"
      bell_s=""
      [ "$bell" = 1 ] && bell_s="🔔"
      printf '%-20s %-6s %-6s %-4s %-10s %s\n' "$name" "$state" "$idle" "$bell_s" "$cmd" "$path"
    done <<<"$merged"
  fi
  exit 0
fi

if [[ "$1" == "--raw" ]]; then
  exec mosh "$DEVBOX_HOST"
fi

SESSION="${1:-main}"

# If launched from within a synced folder, open the remote session in the
# corresponding remote dir. Only affects NEW sessions (-c is ignored when -A
# re-attaches an existing one, so reconnecting never jumps you elsewhere).
CDIR=""
_lib="$(cd "$(dirname "$0")/../remote-dev" 2>/dev/null && pwd)/lib.sh"
if [ -f "$_lib" ]; then
  # shellcheck source=/dev/null
  . "$_lib"
  rhome="$(devbox_remote_home 2>/dev/null)" &&
    CDIR="$(devbox_remote_dir "$DEVBOX_CONFIG" "$PWD" "$rhome")"
fi

if [ -n "$CDIR" ]; then
  exec mosh "$DEVBOX_HOST" -- tmux new-session -A -s "$SESSION" -c "$CDIR"
else
  exec mosh "$DEVBOX_HOST" -- tmux new-session -A -s "$SESSION"
fi
